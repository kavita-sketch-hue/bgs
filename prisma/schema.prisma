// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  role       String   @default("EMPLOYEE") // ADMIN, DEPT_HEAD, EMPLOYEE
  department String?
  assets     Asset[]  @relation("UserAssets")
  claims     Claim[]  @relation("UserClaims")
  managedClaims Claim[] @relation("ManagerClaims")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Asset {
  id           String   @id @default(cuid())
  name         String
  brand        String?
  model        String?
  category     String?
  condition    String   @default("GOOD") // NEW, GOOD, FAIR, POOR
  status       String   @default("AVAILABLE") // AVAILABLE, CLAIMED, REPAIRING, RETIRED
  description  String?
  imageUrl     String?
  quantity     Int      @default(1)
  location     String?
  weight       Float?   // in kg
  priceNew     Float?   // in USD
  ownerId      String?
  owner        User?    @relation("UserAssets", fields: [ownerId], references: [id])
  claims       Claim[]
  repairs      Repair[]
  releaseDate  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Claim {
  id         String   @id @default(cuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id])
  userId     String
  user       User     @relation("UserClaims", fields: [userId], references: [id])
  managerId  String?
  manager    User?    @relation("ManagerClaims", fields: [managerId], references: [id])
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED
  claimDate  DateTime @default(now())
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Repair {
  id           String   @id @default(cuid())
  assetId      String
  asset        Asset    @relation(fields: [assetId], references: [id])
  status       String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  description  String?
  costEstimate Float?
  repairDate   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

